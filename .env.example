# Database Configuration
DATABASE_URL=postgresql://app:app@localhost:5432/app
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app

# AACT Warehouse Configuration
# Set this after running scripts/aact_restore.sh
AACT_DATABASE_URL=postgresql://app:app@localhost:5432/aact

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Application Configuration
# Set to 'true' to use AACT warehouse instead of CT.gov API
USE_AACT=false

# API Configuration
PORT=3001
NODE_ENV=development

# CORS Origins (comma-separated list of allowed origins for production)
# Example: https://your-web-app.up.railway.app,https://custom-domain.com
CORS_ORIGINS=
